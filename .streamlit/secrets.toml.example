# Copy this file into Streamlit Cloud secrets.
# Do not commit a real .streamlit/secrets.toml file.

SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_ANON_KEY = "your-anon-public-key"
SUPABASE_TABLE = "r101_stock_reports"

# Optional: set this if deploying publicly.
APP_PASSWORD = "change-this-password"

# Optional: without this, the app still creates a rule-based report.
OPENAI_API_KEY = "sk-your-openai-key"
OPENAI_MODEL = "gpt-4.1-mini"

# Optional safety fuse for OpenAI API.
# AI will NOT run unless AI_MONTHLY_BUDGET_USD is set.
# Example: if your free credit balance is $5, set budget to 5 and keep a buffer.
AI_MONTHLY_BUDGET_USD = "5.00"
AI_STOP_BUFFER_USD = "0.50"
AI_ESTIMATED_REPORT_COST_USD = "0.02"

# Override only if OpenAI pricing changes or you choose another model.
AI_INPUT_PRICE_PER_1M_USD = "0.40"
AI_OUTPUT_PRICE_PER_1M_USD = "1.60"
