# Copy this file into Streamlit Cloud secrets.
# Do not commit a real .streamlit/secrets.toml file.

SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_ANON_KEY = "your-anon-public-key"
SUPABASE_TABLE = "r101_stock_reports"

# Optional: set this if deploying publicly.
APP_PASSWORD = "change-this-password"

# Optional: without this, the app still creates a rule-based report.
OPENAI_API_KEY = "sk-your-openai-key"
OPENAI_MODEL = "gpt-4.1-mini"
